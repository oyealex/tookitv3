@startuml 设备管理模块类图
skinparam classAttributeIconSize 0
skinparam packageStyle rectangle

' ==================== 模型层 ====================
package "model" {
    class Device {
        - ip: String
        - name: String
        - type: DeviceType
        - model: String
        - version: String
        - username: String
        - password: String
        - createdAt: LocalDateTime
        - updatedAt: LocalDateTime
    }
    
    enum DeviceType {
        ROUTER
        SWITCH
        SERVER
        CAMERA
        IoT_DEVICE
    }
    
    enum DeviceErrorCode {
        DEVICE_NOT_FOUND
        IP_DUPLICATED
        DEVICE_LIMIT_EXCEEDED
        BATCH_SIZE_EXCEEDED
    }
    
    class Result<T> {
        - code: int
        - message: String
        - data: T
        + success(data: T): Result<T>
        + error(code: int, message: String): Result<T>
    }
}

' ==================== 实体层 ====================
package "entity" {
    class DeviceEntity {
        - ip: String
        - name: String
        - type: DeviceType
        - model: String
        - version: String
        - username: String
        - password: String
        - createdAt: LocalDateTime
        - updatedAt: LocalDateTime
    }
}

' ==================== DTO层 ====================
package "model.dto" {
    class DeviceCreateDTO {
        - ip: String
        - name: String
        - type: DeviceType
        - model: String
        - version: String
        - username: String
        - password: String
    }
    
    class DeviceUpdateDTO {
        - name: String
        - type: DeviceType
        - model: String
        - version: String
        - username: String
        - password: String
    }
    
    class DeviceQueryDTO {
        - offset: Integer
        - limit: Integer
        - ip: String
        - name: String
        - type: DeviceType
        - model: String
        - version: String
    }
    
    class BatchResultDTO {
        - successCount: int
        - failCount: int
        - failReasons: List<FailReason>
        + FailReason(line: int, ip: String, reason: String)
    }
}

' ==================== Repository层 ====================
package "repository" {
    interface DeviceJpaRepository {
        + save(entity: DeviceEntity): DeviceEntity
        + findById(ip: String): Optional<DeviceEntity>
        + findByConditions(...): Page<DeviceEntity>
        + countByConditions(...): long
        + deleteById(ip: String): void
        + deleteByIpIn(ips: List<String>): void
        + existsById(ip: String): boolean
    }
    
    class DeviceRepository {
        - jpaRepository: DeviceJpaRepository
        - mapper: DeviceMapper
        + insert(device: Device): void
        + findByIp(ip: String): Optional<Device>
        + findAll(...): List<Device>
        + count(...): long
        + update(device: Device): void
        + deleteByIp(ip: String): void
        + existsByIp(ip: String): boolean
    }
}

' ==================== Mapper层 ====================
package "mapper" {
    class DeviceMapper {
        + toModel(entity: DeviceEntity): Device
        + toEntity(device: Device): DeviceEntity
        + toModelList(entities: List<DeviceEntity>): List<Device>
        + toEntityList(devices: List<Device>): List<DeviceEntity>
    }
}

' ==================== Service层 ====================
package "service" {
    interface DeviceService {
        + addDevice(dto: DeviceCreateDTO): Device
        + addDevices(devices: List<DeviceCreateDTO>): BatchResultDTO
        + getDevice(ip: String): Device
        + getDevices(query: DeviceQueryDTO): List<Device>
        + count(): long
        + count(query: DeviceQueryDTO): long
        + updateDevice(ip: String, dto: DeviceUpdateDTO): Device
        + deleteDevice(ip: String): void
        + deleteDevices(ips: List<String>): BatchResultDTO
    }
    
    class DeviceServiceImpl {
        - deviceRepository: DeviceRepository
        - messageSource: MessageSource
        + addDevice(dto: DeviceCreateDTO): Device
        + addDevices(devices: List<DeviceCreateDTO>): BatchResultDTO
        + getDevice(ip: String): Device
        + getDevices(query: DeviceQueryDTO): List<Device>
        + count(): long
        + count(query: DeviceQueryDTO): long
        + updateDevice(ip: String, dto: DeviceUpdateDTO): Device
        + deleteDevice(ip: String): void
        + deleteDevices(ips: List<String>): BatchResultDTO
        - validateDeviceCreate(dto: DeviceCreateDTO): void
        - checkDeviceLimit(additional: int): void
        - resolveName(name: String, type: DeviceType, ip: String): String
    }
    
    interface DeviceExcelService {
        + exportDevices(devices: List<Device>, response: HttpServletResponse): void
        + downloadTemplate(response: HttpServletResponse): void
        + importDevices(excelData: List<DeviceExcelDTO>): BatchResultDTO
    }
}

' ==================== Controller层 ====================
package "controller" {
    class DeviceController {
        - deviceService: DeviceService
        - deviceExcelService: DeviceExcelService
        + addDevice(dto: DeviceCreateDTO): Result<Device>
        + addDevices(devices: List<DeviceCreateDTO>): Result<BatchResultDTO>
        + getDevice(ip: String): Result<Device>
        + getDevices(query: DeviceQueryDTO): Result<DeviceListResult>
        + updateDevice(ip: String, dto: DeviceUpdateDTO): Result<Device>
        + deleteDevice(ip: String): Result<Void>
        + deleteDevices(ips: List<String>): Result<BatchResultDTO>
        + exportDevices(query: DeviceQueryDTO, response: HttpServletResponse): void
        + downloadTemplate(response: HttpServletResponse): void
        + importDevices(file: MultipartFile): Result<BatchResultDTO>
    }
}

' ==================== 关系定义 ====================

' Device 关联 DeviceType
Device -> DeviceType : uses

' DeviceEntity 关联 DeviceType
DeviceEntity -> DeviceType : uses

' DTO 关联 DeviceType
DeviceCreateDTO -> DeviceType : uses
DeviceQueryDTO -> DeviceType : uses

' Controller 依赖 Service
DeviceController -> DeviceService : uses
DeviceController -> DeviceExcelService : uses

' Service 实现接口
DeviceServiceImpl .up.|> DeviceService

' Repository 依赖 JPA
DeviceRepository -> DeviceJpaRepository : uses

' Mapper 依赖 Entity 和 Model
DeviceMapper -> DeviceEntity : uses
DeviceMapper -> Device : uses

' Service 依赖 Repository
DeviceServiceImpl -> DeviceRepository : uses
DeviceServiceImpl -> DeviceMapper : uses

' Repository 依赖 Mapper
DeviceRepository -> DeviceMapper : uses

' DTO 与 Model 的转换
DeviceController -> DeviceCreateDTO : uses
DeviceController -> DeviceQueryDTO : uses
DeviceController -> DeviceUpdateDTO : uses
DeviceController -> BatchResultDTO : uses

' Result 作为响应类型
DeviceController -> Result : uses

' Excel 内部类
class DeviceExcelService.DeviceExcelDTO

@enduml
